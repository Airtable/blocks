{
  "phabricator.uri" : "https://airtable.phacility.com/",
  "base": "git:merge-base(origin/master)",
  "arc.land.onto.default": "master",
  "load": [
    "lib/arc/arc-airtable-test-engine"
  ],
  "unit.airtable": {
    "build": {
    }
  },
  "aliases": {
    "airdiff": [
      "!branchname=`git branch  | grep '\\*' | cut -d' ' -f2`",
      " && if [ \"$branchname\" == 'development' ]; then echo 'Refusing to \"arc airdiff\" on branch \"'$branchname'\".' > /dev/stderr; false; fi",
      " && echo 'Pushing branch \"'$branchname'\"...'",
      " && git push -u origin $branchname:$branchname",
      " && arc diff --no-amend"
    ],
    "hdiff": [
      "!arc airdiff"
    ]
  }
}
