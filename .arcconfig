{
  "phabricator.uri" : "https://airtable.phacility.com/",
  "base": "git:merge-base(origin/vNext)",
  "arc.land.onto.default": "vNext",
  "aliases": {
    "airdiff": [
      "!branchname=`git branch  | grep '\\*' | cut -d' ' -f2`",
      " && if [ \"$branchname\" == 'master' ]; then echo 'Refusing to \"arc airdiff\" on branch \"'$branchname'\".' > /dev/stderr; false; fi",
      " && echo 'Pushing branch \"'$branchname'\"...'",
      " && git push -u origin $branchname:$branchname",
      " && arc diff --no-amend"
    ],
    "hdiff": [
      "!arc airdiff"
    ]
  }
}