{
    "name": "@airtable/blocks-cli",
    "description": "Official command line tool for Airtable blocks development",
    "version": "0.0.68",
    "homepage": "https://airtable.com/developers/blocks",
    "bin": {
        "block": "bin/block"
    },
    "license": "UNLICENSED",
    "scripts": {
        "ci": "echo '--- cli' && yarn run test",
        "lint": "eslint .",
        "flow": "flow",
        "clean": "rm -rf transpiled node_modules",
        "build:clean": "rm -rf transpiled",
        "build:transpile": "babel . --only src,blocks_backend_wrapper,test --out-dir transpiled",
        "build": "yarn run build:clean && yarn run build:transpile",
        "build:clean-win": "if exist transpiled rmdir /s /q transpiled",
        "build:win": "yarn run build:clean-win & yarn run build:transpile",
        "watch": "yarn build --watch",
        "prepublishOnly": "yarn run build && rm -rf ./transpiled/test ./transpiled/blocks_backend_wrapper/test",
        "pretest": "yarn run lint && yarn run flow",
        "test": "yarn run build && mocha test blocks_backend_wrapper/test",
        "test:smokeTest": "yarn run build && npm_config_registry=https://registry.npmjs.org/ ./transpiled/test/smoke_test.js --blocks_cli_command=\"$PWD/bin/block\"",
        "test:smokeTest-win": "test\\windows_smoke_test.bat",
        "test:releaseSmokeTest": "yarn run build && npm_config_registry=https://registry.npmjs.org/ ./transpiled/test/smoke_test.js --reinstall_from_npm --blocks_cli_command=$(npm config get prefix)/bin/block",
        "test:releaseSmokeTest-win": "test\\windows_release_smoke_test.bat",
        "version": "changelog-publish --github-repo-url 'https://github.com/Airtable/blocks' --git-tag-prefix='@airtable/blocks-cli@' && git add CHANGELOG.md",
        "release": "npm_config_registry=https://registry.npmjs.org/ release-it"
    },
    "files": [
        "/README.md",
        "/bin/block",
        "/keys/",
        "/transpiled/",
        "/blocks_backend_wrapper/package.json",
        "/blocks_backend_wrapper/package-lock.json"
    ],
    "bundledDependencies": [
        "airtable-blocks-backend-wrapper"
    ],
    "dependencies": {
        "@airtable/eslint-plugin-blocks": "^1.0.2",
        "@babel/cli": "^7.7.0",
        "@babel/core": "^7.7.0",
        "@babel/plugin-transform-flow-strip-types": "^7.6.3",
        "@babel/preset-env": "^7.7.1",
        "@babel/preset-react": "^7.7.0",
        "@babel/preset-typescript": "^7.7.0",
        "@deboxsoft/cpx": "^1.5.0",
        "@octokit/rest": "^18.0.10",
        "@sentry/cli": "1.73.0",
        "archiver": "5.0.2",
        "babelify": "^10.0.0",
        "body-parser": "^1.18.3",
        "browserify": "^14.5.0",
        "chalk": "^2.4.1",
        "chokidar": "^3.0.2",
        "cli-ux": "^5.3.2",
        "clipboardy": "^2.1.0",
        "core-js": "^3.6.4",
        "cross-spawn": "^6.0.5",
        "delay": "^4.3.0",
        "envify": "^4.1.0",
        "express": "^4.17.0",
        "form-data": "^2.5.1",
        "fs-extra": "^8.0.1",
        "glob": "^7.1.2",
        "inquirer": "^6.5.0",
        "invariant": "^2.2.4",
        "lodash": "^4.17.14",
        "npm-package-arg": "^6.1.0",
        "path-to-regexp": "^2.2.1",
        "pkg-dir": "^4.2.0",
        "postman-request": "^2.88.1-postman.19",
        "regenerator-runtime": "^0.13.3",
        "semver": "^5.6.0",
        "strip-ansi": "^5.2.0",
        "tar": "^6.0.2",
        "terser": "^3.17.0",
        "update-notifier": "4.1.0",
        "user-agent-bag": "0.2.0",
        "watchify": "^3.9.0",
        "yargs": "^13.2.0"
    },
    "devDependencies": {
        "@airtable-blocks-internal/changelog-publish": "^1.0.2",
        "@babel/register": "^7.7.0",
        "@oclif/test": "^1.2.5",
        "airtable-blocks-backend-wrapper": "file:./blocks_backend_wrapper",
        "babel-eslint": "^10.0.1",
        "babel-preset-minify": "^0.5.1",
        "detect-port": "^1.3.0",
        "eslint": "^5.15.1",
        "eslint-plugin-airtable": "git+ssh://git@github.com/Hyperbase/eslint-plugin-airtable#da42308fa5d9c164794b2d32c96934e54b1195f9",
        "eslint-plugin-flowtype": "^3.4.2",
        "eslint-plugin-react": "^7.6.0",
        "flow-bin": "^0.95.1",
        "flow-typed": "^2.5.2",
        "is-windows": "^1.0.2",
        "mocha": "^5.2.0",
        "proxyquire": "^2.1.0",
        "sinon": "^7.3.2",
        "which": "^1.3.1"
    },
    "engines": {
        "node": ">=12.14.0"
    },
    "release-it": {
        "git": {
            "tagName": "@airtable/blocks-cli@${version}",
            "commitMessage": "Release @airtable/blocks-cli@${version}"
        },
        "hooks": {
            "before:init": "../../bin/check-repo-for-release && yarn run test"
        },
        "npm": {
            "access": "public"
        }
    }
}
