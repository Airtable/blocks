{
    "name": "@airtable/blocks-cli",
    "description": "Official command line tool for Airtable blocks development",
    "version": "0.0.26",
    "bin": {
        "block": "bin/block"
    },
    "license": "UNLICENSED",
    "scripts": {
        "lint": "eslint .",
        "flow": "flow",
        "clean": "rm -rf transpiled node_modules",
        "build:clean": "rm -rf transpiled",
        "build": "yarn run build:clean && babel src --out-dir transpiled",
        "watch": "yarn build --watch",
        "prepublishOnly": "yarn build",
        "pretest": "yarn run lint && yarn run flow",
        "test": "mocha",
        "version": "changelog-publish --github-repo-url 'https://github.com/airtable/blocks' --git-tag-prefix='@airtable/blocks-cli@' && git add CHANGELOG.md",
        "release": "npm_config_registry=https://registry.npmjs.org/ release-it"
    },
    "files": [
        "/README.md",
        "/bin/block",
        "/keys/",
        "/transpiled/"
    ],
    "dependencies": {
        "@airtable/eslint-plugin-blocks": "^1.0.2",
        "@babel/cli": "^7.2.3",
        "@babel/core": "^7.4.0",
        "@babel/plugin-proposal-class-properties": "^7.4.0",
        "@babel/polyfill": "^7.4.0",
        "@babel/preset-env": "^7.4.2",
        "@babel/preset-flow": "^7.0.0",
        "@babel/preset-react": "^7.0.0",
        "archiver": "2.0.0",
        "babelify": "^10.0.0",
        "body-parser": "^1.18.3",
        "browserify": "^14.5.0",
        "chalk": "^2.4.1",
        "chokidar": "^2.0.4",
        "clipboardy": "^2.1.0",
        "cpx": "^1.5.0",
        "cross-spawn": "^6.0.5",
        "envify": "^4.1.0",
        "express": "^4.17.0",
        "fs-extra": "^8.0.1",
        "glob": "^7.1.2",
        "inquirer": "^6.5.0",
        "invariant": "^2.2.4",
        "lodash": "^4.17.14",
        "npm-package-arg": "^6.1.0",
        "path-to-regexp": "^2.2.1",
        "request": "^2.83.0",
        "rollbar": "^2.7.0",
        "semver": "^5.6.0",
        "strip-ansi": "^5.2.0",
        "terser": "^3.17.0",
        "user-agent-bag": "0.2.0",
        "watchify": "^3.9.0",
        "yargs": "^13.2.0"
    },
    "devDependencies": {
        "@airtable-blocks-internal/changelog-publish": "^1.0.2",
        "@babel/register": "^7.4.4",
        "babel-eslint": "^10.0.1",
        "eslint": "^5.15.1",
        "eslint-plugin-airtable": "git+ssh://git@github.com/Hyperbase/eslint-plugin-airtable#da42308fa5d9c164794b2d32c96934e54b1195f9",
        "eslint-plugin-flowtype": "^3.4.2",
        "eslint-plugin-react": "^7.6.0",
        "flow-bin": "^0.95.1",
        "flow-typed": "^2.5.2",
        "mocha": "^5.2.0",
        "proxyquire": "^2.1.0",
        "sinon": "^7.3.2"
    },
    "engines": {
        "node": ">=8.10.0"
    },
    "release-it": {
        "git": {
            "tagName": "@airtable/blocks-cli@${version}",
            "commitMessage": "Release @airtable/blocks-cli@${version}"
        },
        "hooks": {
            "before:init": "../../bin/check-repo-for-release && yarn test",
            "after:release": "git push --tags git@github.com:Airtable/blocks.git master"
        },
        "npm": {
            "access": "restricted"
        }
    }
}
