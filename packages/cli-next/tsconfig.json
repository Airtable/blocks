{
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "importHelpers": true,
        "target": "es2017",
        "module": "commonjs",
        "esModuleInterop": true,
        "outDir": "lib",
        "rootDir": "src",

        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "jsx": "react"
    },
    "include": ["src/**/*"]
}
