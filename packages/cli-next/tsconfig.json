// See `tsconfig-testing.json` for details on preserving test support when
// modifying this file.
{
    "compilerOptions": {
        // begin distinctive configuration for release environment
        "declaration": true,
        "outDir": "lib",
        "rootDir": "src",
        // end distinctive configuration for release environment

        "composite": true,
        "importHelpers": true,
        "target": "es2017",
        "module": "commonjs",
        "esModuleInterop": true,

        "allowJs": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "strictFunctionTypes": true,
        "strictBindCallApply": true,
        "strictPropertyInitialization": true,
        "noImplicitThis": true,
        "alwaysStrict": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "jsx": "react",

        // Some dependencies do not depend on up to date @types definition
        // packages for versions of packages they use and mismatch with other
        // dependencies. Due to normal hoisting (not workspace hoisting), errors
        // are produced in a few libraries.
        "skipLibCheck": true
    },
    // begin distinctive configuration for release environment
    "include": ["src/**/*"]
    // end distinctive configuration for release environment
}
