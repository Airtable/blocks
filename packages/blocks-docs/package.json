{
    "name": "@airtable/blocks-docs",
    "private": true,
    "version": "1.0.0",
    "description": "A service to generate the data file which powers developer-facing API documentation on airtable.com. It is used by the \"sdk\" package and the \"blocks-testing\" package",
    "main": "minify-docs-json.js",
    "bin": {
        "blocks-docs": "bin/blocks-docs"
    },
    "scripts": {
        "ci": "yarn test",
        "build": "tsc -b ./tsconfig.json",
        "lint": "eslint --report-unused-disable-directives --ext .js,.ts,.tsx src",
        "test": "yarn lint && yarn types",
        "types": "tsc"
    },
    "dependencies": {
        "@types/node": "^14.14.31",
        "typedoc": "0.15.4",
        "typedoc-plugin-no-inherit": "~1.1.10",
        "typescript": "~3.7.5"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^2.10.0",
        "@typescript-eslint/parser": "^2.10.0",
        "eslint": "6.7.2",
        "eslint-plugin-airtable": "github:hyperbase/eslint-plugin-airtable#01fef1f",
        "eslint-plugin-import": "^2.19.1"
    },
    "keywords": [],
    "author": "",
    "license": "UNLICENSED"
}
