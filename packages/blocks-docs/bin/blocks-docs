#!/bin/bash

set -e

function resolve {
  cd $script_dir && node -p "require.resolve('$1')"
}

out_file=$1
script_dir=$(dirname $(readlink -f $0))
typedoc_dir=$(dirname $(resolve typedoc/package.json))
typedoc=$typedoc_dir/$(node -p "require('$typedoc_dir/package.json').bin.typedoc")
typedoc_plugin_no_inherit=$(resolve typedoc-plugin-no-inherit)

$typedoc \
  --plugin "${typedoc_plugin_no_inherit},${script_dir}/../typedoc-plugin.js" \
  --json ${out_file} \
  .

node ${script_dir}/../minify-docs-json.js ${out_file}
