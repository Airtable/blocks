{
    "name": "@airtable/blocks",
    "version": "0.0.3",
    "description": "Airtable Blocks SDK",
    "main": "dist/cjs/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "prepare": "npm run build",
        "flow": "flow",
        "test": "npm run flow -- check",
        "lint": "eslint *.js src",
        "lint:quiet": "npm run lint -- --quiet",
        "format": "prettier --write 'src/**/*.js' '*.{json,js,md}'",
        "build:clean": "rm -rf dist",
        "build:babel": "babel src --out-dir dist/cjs --source-maps inline",
        "watch:babel": "npm run build:babel -- --watch",
        "build:flow": "flow-copy-source src dist/cjs",
        "watch:flow": "npm run build:flow -- --watch",
        "build": "npm run build:clean && npm run build:babel && npm run build:flow",
        "watch": "npm run build:clean && concurrently npm:watch:babel npm:watch:flow"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Hyperbase/blocks-sdk.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/Hyperbase/blocks-sdk/issues"
    },
    "homepage": "https://github.com/Hyperbase/blocks-sdk#readme",
    "devDependencies": {
        "@babel/cli": "^7.4.4",
        "@babel/core": "^7.4.4",
        "@babel/plugin-proposal-class-properties": "^7.4.4",
        "@babel/plugin-syntax-flow": "^7.2.0",
        "@babel/plugin-transform-flow-strip-types": "^7.4.4",
        "@babel/plugin-transform-runtime": "^7.4.4",
        "@babel/preset-env": "^7.4.4",
        "@babel/preset-react": "^7.0.0",
        "babel-eslint": "^10.0.1",
        "babel-plugin-transform-define": "^1.3.1",
        "concurrently": "^4.1.0",
        "eslint": "5.16.0",
        "eslint-plugin-airtable": "github:hyperbase/eslint-plugin-airtable",
        "eslint-plugin-flowtype": "3.9.0",
        "eslint-plugin-import": "^2.17.2",
        "eslint-plugin-react": "^7.13.0",
        "eslint-plugin-react-hooks": "^1.6.0",
        "flow-bin": "0.98.1",
        "flow-copy-source": "^2.0.6",
        "husky": "^2.3.0",
        "lint-staged": "^8.1.7",
        "prettier": "^1.17.1",
        "pretty-quick": "^1.10.0"
    },
    "dependencies": {
        "@babel/runtime-corejs3": "^7.4.4",
        "classnames": "2.2.6",
        "core-js": "^3.0.1",
        "invariant": "2.2.4",
        "prop-types": "15.7.2"
    },
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged && lint-staged && npm run prepare && git add dist"
        }
    },
    "lint-staged": {
        "*.js,!dist": [
            "eslint --quiet"
        ]
    }
}
