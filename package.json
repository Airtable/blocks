{
    "name": "@airtable/blocks",
    "version": "0.0.2",
    "description": "Airtable Blocks SDK",
    "main": "dist/cjs/index.js",
    "files": [
        "dist"
    ],
    "scripts": {
        "prepare": "npm run build",
        "flow": "flow",
        "test": "npm run flow -- check",
        "format": "prettier --write 'src/**/*.js' '*.{json,js,md}'",
        "build:clean": "rm -rf dist",
        "build:babel": "babel src --out-dir dist/cjs --source-maps inline",
        "watch:babel": "npm run build:babel -- --watch",
        "build:flow": "flow-copy-source src dist/cjs",
        "watch:flow": "npm run build:flow -- --watch",
        "build": "npm run build:clean && npm run build:babel && npm run build:flow",
        "watch": "npm run build:clean && concurrently npm:watch:babel npm:watch:flow"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Hyperbase/blocks-sdk.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/Hyperbase/blocks-sdk/issues"
    },
    "homepage": "https://github.com/Hyperbase/blocks-sdk#readme",
    "devDependencies": {
        "@babel/cli": "^7.4.3",
        "@babel/core": "^7.4.3",
        "@babel/plugin-proposal-class-properties": "^7.4.0",
        "@babel/plugin-syntax-flow": "^7.2.0",
        "@babel/plugin-transform-flow-strip-types": "^7.4.4",
        "@babel/plugin-transform-runtime": "^7.4.3",
        "@babel/preset-env": "^7.4.3",
        "@babel/preset-react": "^7.0.0",
        "babel-plugin-transform-define": "^1.3.1",
        "concurrently": "^4.1.0",
        "flow-bin": "0.81.0",
        "flow-copy-source": "^2.0.3",
        "husky": "^2.1.0",
        "prettier": "^1.17.0",
        "pretty-quick": "^1.10.0"
    },
    "dependencies": {
        "@babel/runtime-corejs3": "^7.4.3",
        "classnames": "2.1.3",
        "core-js": "^3.0.1",
        "invariant": "2.2.2",
        "prop-types": "15.5.10"
    },
    "husky": {
        "hooks": {
            "pre-commit": "pretty-quick --staged"
        }
    }
}
